# ── Telegram ───────────────────────────────────────────────────
BOT_TOKEN=7123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=@YourNewsAgentBot
CHANNEL_ID=@yourchannel              # или числовой ID: -1001234567890
ADMIN_IDS=123456789,987654321        # Telegram user ID через запятую

# ── Mini App URL (твой домен, обязательно HTTPS) ───────────────
WEBAPP_URL=https://yourdomain.com
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_SECRET=change_me_to_random_string

# ── AI ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GEMINI_API_KEY=your_api_key

# ── Infrastructure ─────────────────────────────────────────────
DOMAIN=yourdomain.com
SSL_EMAIL=your@email.com
DB_PASSWORD=supersecretpassword


# Авто-проставляются в docker-compose, менять не нужно:
